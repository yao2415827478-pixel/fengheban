# ============================================
# 布鲁计划 - 开发环境配置
# ============================================
# 复制此文件为 .env.local 后修改其中的值
# .env.local 不会提交到版本控制

# 后端 API 地址
# 开发环境：通常指向本地后端服务
VITE_API_BASE_URL=http://localhost:3001

# 是否启用开发调试模式（跳过登录/支付直接进入首页）
# 生产环境必须设为 false 或删除此配置
VITE_DEV_BYPASS=false
