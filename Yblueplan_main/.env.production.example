# ============================================
# 布鲁计划 - 生产环境配置
# ============================================
# 复制此文件为 .env.production.local 后修改其中的值
# .env.production.local 不会提交到版本控制

# 后端 API 地址（必须填写你的真实后端地址）
# 示例: https://your-backend-domain.com
# 当前配置: https://blue-plan1.cn
VITE_API_BASE_URL=https://blue-plan1.cn

# 生产环境必须关闭调试模式
VITE_DEV_BYPASS=false
