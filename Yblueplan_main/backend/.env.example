# 布鲁计划后端 - 环境变量模板
# 复制此文件为 .env 后修改

# 服务器端口
PORT=3001

# 允许跨域来源（逗号分隔，按需覆盖）
# APP_ALLOWED_ORIGINS=https://blue-plan1.cn,https://www.blue-plan1.cn,http://localhost,https://localhost,capacitor://localhost

# PostgreSQL 配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=blueplan

# JWT 密钥（生产环境务必修改）
JWT_SECRET=blueplan-secret-key-change-in-production

# 内部运营接口密钥（用于提现审核等内部接口）
INTERNAL_ADMIN_KEY=

# 短信服务模式：mock=开发模式(固定验证码123456)，aliyun=阿里云短信
SMS_MODE=mock

# 阿里云短信配置（SMS_MODE=aliyun 时生效）
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=武汉市洪山区乔乔尼服装店
SMS_TEMPLATE_CODE=SMS_501700483

# 支付宝配置
# ALIPAY_APP_ID=2021006132651155
# ALIPAY_APP_PUBLIC_KEY=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_ALIPAY_PUBLIC_KEY=
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# ALIPAY_NOTIFY_URL=https://blue-plan1.cn/alipay-notify
# ALIPAY_RETURN_URL=https://blue-plan1.cn/alipay-return
